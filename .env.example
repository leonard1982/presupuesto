APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=AUTO
APP_TIMEZONE=America/Bogota
APP_ENABLE_PWA=false
APP_SESSION_NAME=presupuesto_session
APP_SESSION_LIFETIME_SECONDS=43200
APP_SESSION_LIFETIME_MIN_SECONDS=28800
APP_SESSION_LIFETIME_MAX_SECONDS=172800
APP_SESSION_LIFETIME_COOKIE_NAME=presupuesto_session_lifetime
APP_SESSION_LIFETIME_OPTIONS_HOURS=8,12,24,48
APP_REMEMBER_USERNAME_COOKIE_NAME=presupuesto_recordado_usuario
APP_REMEMBER_USERNAME_DAYS=30
APP_CSRF_TOKEN_NAME=csrf_token
APP_ASSET_VERSION=0.1.0

DB_HOST=127.0.0.1
DB_PORT=3311
DB_NAME=presupuestos
DB_NAME_LEGACY=presupuestos_legacy
DB_NAME_NEW=presupuestos_nuevo
DB_USER=root
DB_PASS=CHANGE_ME
DB_CHARSET=utf8mb4

FILES_MAX_UPLOAD_MB=10
FILES_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,pdf
FILES_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf

MAIL_HOST=
MAIL_PORT=25
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_ENCRYPTION=none
MAIL_TIMEOUT_SECONDS=20

MAIL_INBOX_HOST=
MAIL_INBOX_PORT=993
MAIL_INBOX_USER=
MAIL_INBOX_PASS=
MAIL_INBOX_FOLDER=INBOX
MAIL_INBOX_ENCRYPTION=ssl
MAIL_INBOX_NOVALIDATE_CERT=true
MAIL_INBOX_MAX_MESSAGES=35

OPENAI_API_KEY_PRESUPUESTO_PERSONAL=
OPENAI_KPI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
